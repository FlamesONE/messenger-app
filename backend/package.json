{
  "name": "message-app-backend",
  "version": "1.0.50",
  "scripts": {
    "dev": "bun run --watch src/main.ts",
    "build": "bun build --compile --minify-whitespace --minify-syntax --target bun-linux-x64 --outfile dist/server src/index.ts",
    "start": "NODE_ENV=production bun src/index.ts",
    "lint": "biome check .",
    "format": "biome format --write .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1000.0",
    "@aws-sdk/s3-request-presigner": "^3.1000.0",
    "@elysiajs/bearer": "^1.4.3",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/jwt": "^1.4.1",
    "@elysiajs/openapi": "^1.4.14",
    "@types/bcrypt": "^6.0.0",
    "@types/pg": "^8.18.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.70.1",
    "cassandra-driver": "^4.8.0",
    "drizzle-orm": "^0.45.1",
    "drizzle-typebox": "^0.3.3",
    "elysia": "^1.4.27",
    "elysia-rate-limit": "^4.5.0",
    "ioredis": "^5.10.0",
    "meilisearch": "^0.55.0",
    "nanoid": "^5.1.6",
    "pg": "^8.19.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "bun-types": "latest",
    "drizzle-kit": "^0.31.9"
  },
  "module": "src/main.js"
}
